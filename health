<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="健康管理">
<meta name="theme-color" content="#0d1117">
<title>健康管理</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root{--bg:#0d1117;--card:#161b22;--border:#21262d;--accent:#58a6ff;--green:#3fb950;--yellow:#d29922;--red:#f85149;--text:#e6edf3;--muted:#8b949e;--safe-top:env(safe-area-inset-top,44px);--safe-bot:env(safe-area-inset-bottom,20px)}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{background:var(--bg);color:var(--text);font-family:-apple-system,'Hiragino Sans',sans-serif;min-height:100dvh;padding-bottom:calc(80px + var(--safe-bot))}
.header{background:var(--card);border-bottom:1px solid var(--border);padding:calc(var(--safe-top) + 12px) 20px 0;position:sticky;top:0;z-index:100}
.header-top{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:12px}
.header-title{font-size:22px;font-weight:700;letter-spacing:-.02em}
.header-date{font-size:12px;color:var(--muted)}
.tabs{display:flex}
.tab{flex:1;padding:10px 0;background:none;border:none;color:var(--muted);font-size:13px;font-weight:500;cursor:pointer;border-bottom:2px solid transparent;font-family:inherit;transition:all .2s}
.tab.active{color:var(--text);border-bottom-color:var(--accent);font-weight:600}
.content{padding:16px}
.card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px;margin-bottom:14px}
.card-label{font-size:11px;color:var(--muted);letter-spacing:.06em;text-transform:uppercase;margin-bottom:14px;font-weight:600}
.upload-card{background:var(--card);border:1px dashed var(--border);border-radius:14px;padding:16px;margin-bottom:14px}
.upload-btn{display:block;width:100%;background:linear-gradient(135deg,#1f6feb 0%,#388bfd 100%);color:#fff;border:none;border-radius:10px;padding:13px;font-size:15px;font-weight:600;font-family:inherit;cursor:pointer;transition:opacity .2s}
.upload-btn:disabled{opacity:.5}
.upload-btn.sm{background:var(--bg);border:1px solid var(--border);color:var(--text);font-size:13px;font-weight:500;padding:8px 12px;width:auto}
.upload-hint{font-size:11px;color:var(--muted);text-align:center;margin-top:8px}
.ai-preview{margin-top:12px;padding:12px;background:rgba(88,166,255,.08);border:1px solid rgba(88,166,255,.2);border-radius:10px;display:none}
.ai-preview.show{display:block}
.ai-title{font-size:12px;color:var(--accent);font-weight:600;margin-bottom:8px}
.ai-grid{display:grid;grid-template-columns:1fr 1fr;gap:6px;font-size:13px}
.status{font-size:12px;text-align:center;min-height:18px;margin:6px 0}
.status.ok{color:var(--green)}.status.err{color:var(--red)}
.metric{margin-bottom:14px}
.metric:last-child{margin-bottom:0}
.mrow{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px}
.mlabel{font-size:12px;color:var(--muted)}
.mvalue{font-size:15px;font-weight:700;font-variant-numeric:tabular-nums}
.msub{font-size:11px;color:var(--muted);font-weight:400}
.bar-track{height:5px;border-radius:3px;background:var(--border);overflow:hidden}
.bar-fill{height:100%;border-radius:3px;transition:width .5s}
.mnote{font-size:10px;color:var(--muted);text-align:right;margin-top:3px}
.mnote.warn{color:var(--red)}
.vitals-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.vgrid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:14px}
.vfield label{display:block;font-size:10px;color:var(--muted);margin-bottom:4px}
.vwrap{position:relative}
.vinput{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:8px;padding:9px 22px 9px 9px;color:var(--text);font-size:18px;font-weight:700;font-family:inherit;outline:none;font-variant-numeric:tabular-nums}
.vunit{position:absolute;right:6px;top:50%;transform:translateY(-50%);font-size:9px;color:var(--muted)}
.save-btn{width:100%;background:var(--green);color:#000;border:none;border-radius:10px;padding:13px;font-size:15px;font-weight:700;font-family:inherit;cursor:pointer}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.stat-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px}
.stat-label{font-size:11px;color:var(--muted);margin-bottom:6px}
.stat-value{font-size:28px;font-weight:700;font-variant-numeric:tabular-nums}
.stat-unit{font-size:12px;color:var(--muted);margin-top:2px}
.chart-wrap{position:relative;height:130px}
.hist-table{width:100%;border-collapse:collapse;font-size:12px}
.hist-table th{padding:6px 4px;color:var(--muted);text-align:right;font-weight:500;border-bottom:1px solid var(--border)}
.hist-table th:first-child{text-align:left}
.hist-table td{padding:8px 4px;text-align:right;font-variant-numeric:tabular-nums}
.hist-table td:first-child{text-align:left;color:var(--muted)}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:6px}
@keyframes spin{to{transform:rotate(360deg)}}
.hidden{display:none}
/* Key banner */
.kbanner{display:flex;align-items:center;justify-content:space-between;background:rgba(248,81,73,.08);border:1px solid rgba(248,81,73,.25);border-radius:12px;padding:11px 14px;margin-bottom:14px;gap:10px}
.kbanner.ok{background:rgba(63,185,80,.08);border-color:rgba(63,185,80,.25)}
.kbanner-text{font-size:12px;color:var(--muted);flex:1;line-height:1.4}
.kbanner-btn{background:var(--accent);color:#000;border:none;border-radius:8px;padding:7px 12px;font-size:12px;font-weight:700;font-family:inherit;cursor:pointer;white-space:nowrap}
/* Modal */
.overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.8);align-items:flex-end;justify-content:center}
.overlay.show{display:flex}
.modal{background:var(--card);border:1px solid var(--border);border-radius:18px 18px 0 0;padding:28px 24px calc(28px + var(--safe-bot));width:100%}
.modal-title{font-size:18px;font-weight:700;margin-bottom:8px}
.modal-desc{font-size:13px;color:var(--muted);margin-bottom:18px;line-height:1.6}
.modal-input{width:100%;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:13px;color:var(--text);font-size:14px;font-family:monospace;outline:none;margin-bottom:12px}
.modal-save{width:100%;background:var(--accent);color:#000;border:none;border-radius:10px;padding:13px;font-size:15px;font-weight:700;font-family:inherit;cursor:pointer;margin-bottom:10px}
.modal-cancel{width:100%;background:none;border:1px solid var(--border);color:var(--muted);border-radius:10px;padding:11px;font-size:14px;font-family:inherit;cursor:pointer}
.modal-note{font-size:11px;color:var(--muted);margin-top:14px;line-height:1.6}
</style>
</head>
