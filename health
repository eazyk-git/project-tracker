<script>
const T={calories:{max:1800,min:1600,unit:'kcal',label:'カロリー',color:'#ffa657'},protein:{max:999,min:90,unit:'g',label:'タンパク質',color:'#79c0ff'},sodium:{max:6,min:0,unit:'g',label:'塩分',color:'#ff7b72'},fiber:{max:999,min:18,unit:'g',label:'食物繊維',color:'#56d364'}};
let td={calories:0,protein:0,sodium:0,fiber:0,bp_sys:0,bp_dia:0,weight:0},charts={};
const key=()=>todayKey();
const todayKey=()=>{const d=new Date();return`${d.getMonth()+1}/${d.getDate()}`};
const lh=()=>JSON.parse(localStorage.getItem('hh')||'[]');
const sh=h=>localStorage.setItem('hh',JSON.stringify(h));
const gk=()=>localStorage.getItem('ak')||'';

function upsert(data){const h=lh().filter(d=>d.date!==todayKey());h.push({...data,date:todayKey()});sh(h.slice(-14))}

window.onload=()=>{
  document.getElementById('headerDate').textContent=new Date().toLocaleDateString('ja-JP',{month:'long',day:'numeric',weekday:'short'});
  const e=lh().find(d=>d.date===todayKey());
  if(e){td=e;if(e.bp_sys)document.getElementById('bpSys').value=e.bp_sys;if(e.bp_dia)document.getElementById('bpDia').value=e.bp_dia;if(e.weight)document.getElementById('weight').value=e.weight;}
  updateBanner();renderN();renderS();
};

function updateBanner(){
  const k=gk(),b=document.getElementById('kbanner'),t=document.getElementById('kbanner-text'),btn=document.getElementById('kbanner-btn');
  if(k){b.className='kbanner ok';t.textContent='✓ APIキー設定済み — スクショ読み取り有効';btn.textContent='変更';}
  else{b.className='kbanner';t.textContent='⚠ APIキー未設定 — タップして設定するとスクショ自動読み取りが使えます';btn.textContent='設定する';}
}
function openModal(){document.getElementById('keyInput').value=gk();document.getElementById('overlay').classList.add('show')}
function closeModal(){document.getElementById('overlay').classList.remove('show')}
function saveKey(){const v=document.getElementById('keyInput').value.trim();if(v)localStorage.setItem('ak',v);closeModal();updateBanner();setStatus('✓ APIキーを保存しました')}

function showTab(n){
  ['today','trend','history'].forEach((t,i)=>{
    document.getElementById('tab-'+t).classList.toggle('hidden',t!==n);
    document.querySelectorAll('.tab')[i].classList.toggle('active',t===n);
  });
  if(n==='trend')renderCharts();
  if(n==='history')renderHistory();
}

function setStatus(msg,type='ok'){
  const el=document.getElementById('statusMsg');
  el.textContent=msg;el.className='status '+type;
  if(type==='ok')setTimeout(()=>{el.textContent='';el.className='status'},3500);
}

async function toB64(file){
  return new Promise((res,rej)=>{
    const img=new Image();
    img.onload=()=>{
      const s=Math.min(1,1200/Math.max(img.width,img.height));
      const c=document.createElement('canvas');c.width=img.width*s;c.height=img.height*s;
      c.getContext('2d').drawImage(img,0,0,c.width,c.height);
      res(c.toDataURL('image/jpeg',.85).split(',')[1]);
    };
    img.onerror=rej;img.src=URL.createObjectURL(file);
  });
}

async function callClaude(b64,prompt){
  const k=gk();
  if(!k)throw new Error('APIキーが未設定です。上のバナーから設定してください');
  const r=await fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json','anthropic-version':'2023-06-01','x-api-key':k},
    body:JSON.stringify({model:'claude-haiku-4-5-20251001',max_tokens:300,messages:[{role:'user',content:[{type:'image',source:{type:'base64',media_type:'image/jpeg',data:b64}},{type:'text',text:prompt}]}]})
  });
  const data=await r.json();
  if(!r.ok)throw new Error(data?.error?.message||JSON.stringify(data).slice(0,80));
  return data.content?.[0]?.text||'{}';
}

async function handleKalo(e){
  const f=e.target.files[0];if(!f)return;
  const btn=document.getElementById('kaloBtn');
  btn.disabled=true;btn.innerHTML='<span class="spinner"></span>解析中...';e.target.value='';
  try{
    const b64=await toB64(f);
    const txt=await callClaude(b64,'カロミルの食事記録スクリーンショットから栄養数値をJSONのみで返してください。説明不要。\n形式: {"calories":整数,"protein":小数1桁,"sodium":小数1桁,"fiber":小数1桁}\n読取不能は0');
    const p=JSON.parse(txt.replace(/```json|```/g,'').trim());
    td={...td,...p};
    document.getElementById('kaloGrid').innerHTML=[['カロリー',p.calories,'kcal'],['タンパク質',p.protein,'g'],['塩分',p.sodium,'g'],['食物繊維',p.fiber,'g']].map(([l,v,u])=>`<div>${l}: <strong>${v}${u}</strong></div>`).join('');
    document.getElementById('kaloPreview').classList.add('show');
    renderN();setStatus('✓ 読み取り完了。「保存する」で確定');
  }catch(err){setStatus(err.message.slice(0,100),'err')}
  btn.disabled=false;btn.innerHTML='📷 カロミルのスクショを読み込む';
}

async function handleOmron(e){
  const f=e.target.files[0];if(!f)return;
  const btn=document.getElementById('omronBtn');
  btn.disabled=true;btn.innerHTML='<span class="spinner"></span>解析中';e.target.value='';
  try{
    const b64=await toB64(f);
    const txt=await callClaude(b64,'オムロンコネクトの血圧・体重スクリーンショットから数値をJSONのみで返してください。説明不要。\n形式: {"bp_sys":整数,"bp_dia":整数,"weight":小数1桁}\n読取不能は0');
    const p=JSON.parse(txt.replace(/```json|```/g,'').trim());
    if(p.bp_sys)document.getElementById('bpSys').value=p.bp_sys;
    if(p.bp_dia)document.getElementById('bpDia').value=p.bp_dia;
    if(p.weight)document.getElementById('weight').value=p.weight;
    document.getElementById('omronBadge').style.display='inline-block';
    setStatus('✓ オムロンデータ読み取り完了');
  }catch(err){setStatus(err.message.slice(0,100),'err')}
  btn.disabled=false;btn.innerHTML='📱 オムロンコネクト';
}

function saveToday(){
  td={...td,bp_sys:parseFloat(document.getElementById('bpSys').value)||0,bp_dia:parseFloat(document.getElementById('bpDia').value)||0,weight:parseFloat(document.getElementById('weight').value)||0};
  upsert(td);renderS();
  document.getElementById('kaloPreview').classList.remove('show');
  document.getElementById('omronBadge').style.display='none';
  setStatus('✓ 保存しました');
}

function renderN(){
  document.getElementById('nutritionBars').innerHTML=Object.entries(T).map(([k,t])=>{
    const v=td[k]||0,over=t.max<999&&v>t.max;
    const pct=t.max<999?Math.min(v/t.max*100,100):v>0?Math.min(v/t.min*100,100):0;
    const col=over?'#f85149':(t.min>0&&v>0&&v<t.min)?'#d29922':t.color;
    const note=t.max<999&&v>0?(over?`⚠ +${(v-t.max).toFixed(1)}${t.unit} オーバー`:`残り ${(t.max-v).toFixed(1)}${t.unit}`):(t.min>0&&v>0?`目標 ${t.min}${t.unit}`:'');
    return`<div class="metric"><div class="mrow"><span class="mlabel">${t.label}</span><span class="mvalue" style="color:${col}">${v>0?v+t.unit:'—'}${t.max<999&&v>0?`<span class="msub"> / ${t.max}${t.unit}</span>`:''}</span></div><div class="bar-track"><div class="bar-fill" style="width:${pct}%;background:${col}"></div></div>${note?`<div class="mnote ${over?'warn':''}">${note}</div>`:''}</div>`;
  }).join('');
}

function renderS(){
  const{bp_sys:s,bp_dia:d,weight:w}=td;
  const be=document.getElementById('bpDisplay');be.textContent=s&&d?`${s}/${d}`:'—';be.style.color=s>140?'#f85149':s>130?'#d29922':'#e6edf3';
  const we=document.getElementById('weightDisplay');we.textContent=w||'—';we.style.color=w>80?'#d29922':'#e6edf3';
}

function renderCharts(){
  const h=lh();if(h.length<2)return;
  const lb=h.map(d=>d.date);
  [[' cSodium',h.map(d=>d.sodium),'#ff7b72'],['cProtein',h.map(d=>d.protein),'#79c0ff'],['cWeight',h.map(d=>d.weight),'#bc8cff'],['cBp',h.map(d=>d.bp_sys),'#ff9bce']].forEach(([id,data,color])=>{
    const cid=id.trim();
    if(charts[cid])charts[cid].destroy();
    charts[cid]=new Chart(document.getElementById(cid),{type:'line',data:{labels:lb,datasets:[{data,borderColor:color,backgroundColor:color+'22',borderWidth:2,pointRadius:3,fill:true,tension:.3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#8b949e',font:{size:10}},grid:{color:'#21262d'}},y:{ticks:{color:'#8b949e',font:{size:10}},grid:{color:'#21262d'}}},animation:{duration:400}}});
  });
}

function renderHistory(){
  document.getElementById('histBody').innerHTML=lh().slice().reverse().map(d=>`<tr><td>${d.date}</td><td style="color:${d.sodium>6?'#f85149':'#e6edf3'}">${d.sodium||'—'}g</td><td style="color:${d.protein>0&&d.protein<90?'#d29922':'#e6edf3'}">${d.protein||'—'}g</td><td style="color:${d.bp_sys>140?'#f85149':d.bp_sys>130?'#d29922':'#e6edf3'}">${d.bp_sys&&d.bp_dia?d.bp_sys+'/'+d.bp_dia:'—'}</td><td>${d.weight||'—'}kg</td></tr>`).join('');
}

function clearAll(){
  if(confirm('すべての記録を削除してもよろしいですか？')){
    localStorage.removeItem('hh');td={calories:0,protein:0,sodium:0,fiber:0,bp_sys:0,bp_dia:0,weight:0};
    ['bpSys','bpDia','weight'].forEach(id=>document.getElementById(id).value='');
    renderN();renderS();setStatus('リセットしました');
  }
}
</script>

